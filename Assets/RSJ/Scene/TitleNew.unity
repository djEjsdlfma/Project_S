  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b2d8d805d3494ae18b285838c409340f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LSW._02._Code.UI.Tutorial.Current.HelpUI
  helpListButton: {fileID: -8308409750685625227, guid: 232ac9cf129cae84baaf30f7b0a494f2, type: 3}
  content: {fileID: 879406142}
  helpImage: {fileID: 613201494}
  helpText: {fileID: 492103641}
  pageText: {fileID: 1437341508}
  helpDataList:
  - helpBtnName: "\uB3C4\uC6C0\uB9D0\uC774\uB780?"
    helpUIData:
    - helpImage: {fileID: 658738919576576260, guid: e7ff46a4987e1f64d97de7dd4ba4de63, type: 3}
      helpText: "\uC5EC\uAE30\uC5D0\uC11C \uC5EC\uB7EC\uAC00\uC9C0 \uAC8C\uC784 \uC815\uBCF4\uB97C
        \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - helpBtnName: "\uB300\uD654"
    helpUIData:
    - helpImage: {fileID: 309752576124550689, guid: 213979cb4cfb091479956070fd79f1ca, type: 3}
      helpText: "\uC190\uB2D8\uC758 \uD504\uB85C\uD544\uC744 \uB20C\uB7EC \uB300\uD654\uB97C
        \uC2DC\uC791\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uADF8\uB9AC\uACE0 d\uD0A4\uB97C
        \uB20C\uB7EC \uB300\uD654\uB97C \uBE60\uB974\uAC8C \uC9C4\uD589\uD560 \uC218
        \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: 9102470370157027219, guid: 90f488f9cce85c140b7549176ef69657, type: 3}
      helpText: "\uB300\uD654 \uC911\uAC04\uC5D0\uB294 \uC120\uD0DD\uC9C0\uAC00 \uC874\uC7AC\uD569\uB2C8\uB2E4.\n\uC120\uD0DD\uC9C0\uC758
        \uACB0\uACFC\uC5D0 \uB530\uB77C \uACB0\uACFC\uAC00 \uBCC0\uD654\uD569\uB2C8\uB2E4."
    - helpImage: {fileID: 2019216331832324592, guid: 6e0fa4ebe71c03e40b3085aa276b2024, type: 3}
      helpText: "10\uC77C\uCC28\uAE4C\uC9C0\uC758 \uB300\uD654\uC758 \uB05D\uC5D0
        \uCD1B\uBD88\uC774 \uD65C\uC131\uD654\uB429\uB2C8\uB2E4.\n\uB20C\uB7EC\uC11C
        \uB2E4\uC74C \uB0A0\uB85C \uB118\uC5B4 \uAC00\uC2E4\uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: -4771861204046143979, guid: 975644eed763ea2428b53c7575197f6b, type: 3}
      helpText: "11\uC77C\uCC28\uBD80\uD130 \uB300\uD654\uC758 \uB05D\uC5D0 \uCC3B\uC794\uC774
        \uD65C\uC131\uD654\uB429\uB2C8\uB2E4.\n\uB20C\uB7EC\uC11C \uB0B4\uBA74\uC138\uACC4\uB85C
        \uC9C4\uC785\uD569\uB2C8\uB2E4."
  - helpBtnName: "\uBA54\uBAA8"
    helpUIData:
    - helpImage: {fileID: 21300000, guid: ef33ac125d4c76743863e6fe5de31ba3, type: 3}
      helpText: "\uC790\uC2E0\uC774 \uC5B4\uB5A0\uD55C \uB0B4\uC6A9\uC744 \uAE30\uB85D\uD574\uB450\uAE30
        \uC704\uD574 \uBA54\uBAA8\uC7A5\uC744 \uC4F8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: 21300000, guid: 305f7fe41adc06240a7442a19468ccf0, type: 3}
      helpText: "\uC0C8 \uBA54\uBAA8 \uBC84\uD2BC\uC744 \uB204\uB97C \uC2DC \uC0C8\uB85C\uC6B4
        \uBA54\uBAA8\uB97C \uAE30\uB85D\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: 21300000, guid: 1166f8036b5be2b49baae0e91ce23c22, type: 3}
      helpText: "\uBA54\uBAA8\uB97C \uAE30\uB85D \uD6C4 \uC800\uC7A5 \uBC84\uD2BC\uC744
        \uB204\uB97C \uC2DC \uC790\uC2E0\uC774 \uAE30\uB85D\uD55C \uB0B4\uC6A9\uC774
        \uC800\uC7A5\uB429\uB2C8\uB2E4."
  - helpBtnName: "\uC0AC\uC9C4"
    helpUIData:
    - helpImage: {fileID: 21300000, guid: 738d05cc070048542b9a7c5ce8a088b1, type: 3}
      helpText: "\uAC01 \uC190\uB2D8\uB9C8\uB2E4 \uC790\uC2E0\uC774 \uC5EC\uD0DC\uAE4C\uC9C0
        \uC5C5\uB85C\uB4DC\uD55C \uC0AC\uC9C4\uB4E4\uC744 \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: 21300000, guid: 13e078b08c5e3294ca2f31f4fab31963, type: 3}
      helpText: "\uC190\uB2D8\uC744 \uCC98\uC74C \uB9CC\uB0A0 \uB584\uB9C8\uB2E4
        \uD3F4\uB354\uC758 \uAC2F\uC218\uAC00 \uC810\uC810 \uB298\uC5B4\uB0A9\uB2C8\uB2E4."
  - helpBtnName: "\uD53C\uB4DC"
    helpUIData:
    - helpImage: {fileID: 2267328817810217601, guid: c438326e500666e488b4be934376ab54, type: 3}
      helpText: "\uD53C\uB4DC\uC5D0\uC11C \uAC8C\uC2DC\uBB3C\uC744 \uC2DC\uD568\uC73C\uB85C\uC368
        \uC190\uB2D8\uACFC\uC758 \uB300\uD654\uB97C\n\uC2DC\uC791\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - helpBtnName: "\uB0B4\uBA74\uC138\uACC4"
    helpUIData:
    - helpImage: {fileID: -4771861204046143979, guid: 975644eed763ea2428b53c7575197f6b, type: 3}
      helpText: "11\uC77C\uCC28 \uBD80\uD130\uB294 \uCC3B\uC794\uC744 \uB20C\uB7EC\n\uB0B4\uBA74\uC138\uACC4\uB85C
        \uB4E4\uC5B4\uAC08 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: -5952984556162588813, guid: 57ba11131aa32a4419e117164a747d99, type: 3}
      helpText: "A\uD0A4\uC640 D\uD0A4\uB85C \uC774\uB3D9 \uC2A4\uD398\uC774\uC2A4\uBC14\uB85C
        \uC810\uD504 \uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: -5952984556162588813, guid: 57ba11131aa32a4419e117164a747d99, type: 3}
      helpText: "F\uD0A4\uB85C \uC81C\uCD9C \uC0AC\uC9C4\uC744 \uCC0D\uACE0\nG\uD0A4\uB85C
        \uC624\uBE0C\uC81D\uD2B8 \uC774\uB3D9 \uBC0F \uBCF5\uC0AC\uB97C \uD560 \uC218
        \uC788\uC2B5\uB2C8\uB2E4."
    - helpImage: {fileID: -5952984556162588813, guid: 57ba11131aa32a4419e117164a747d99, type: 3}
      helpText: "\uC81C\uCD9C\uC6A9 \uC0AC\uC9C4\uC740 \uCD5C\uB300 5\uC7A5 \uAE4C\uC9C0
        \uCC0D\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - helpBtnName: "\uC5C5\uB85C\uB4DC"
    helpUIData:
    - helpImage: {fileID: 21300000, guid: b60a15a66c885b84d9a4bc71b1a1306b, type: 3}
      helpText: "\uB0B4\uBA74 \uC138\uACC4\uC5D0\uC11C \uB098\uC624\uAC8C \uB418\uBA74
