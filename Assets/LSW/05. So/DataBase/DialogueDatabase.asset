%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b3003bb6e9f448f7a9b91fc47bd08e67, type: 3}
  m_Name: DialogueDatabase
  m_EditorClassIdentifier: Assembly-CSharp::LSW._02._Code.So.DialogueDatabaseSo
  sheets:
  - sheetName: "\uC774\uC7AC\uC724"
    guestType: 1
    dialogues:
    - key: DAY1_NPC_NORM_001_1
      id: 110011
      day: 1
      seq: 1
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_002_2
      content: "\uAC10\uC815 \uC758\uB8B0\uC785\uB2C8\uB2E4. \uBB3C\uAC74\uC774 \uC544\uB2C8\uB77C
        \uAE30\uC5B5\uC785\uB2C8\uB2E4. \uC774\uB7F0 \uC758\uB8B0\uB3C4 \uBC1B\uC73C\uC2ED\uB2C8\uAE4C."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_002_2
      id: 120021
      day: 1
      seq: 2
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_003_3
      content: "\uAE30\uC5B5\uB3C4 \uAC10\uC815 \uB300\uC0C1\uC774 \uB418\uAE34 \uD558\uC8E0.
        \u2026\uCC9C\uCC9C\uD788 \uB4E4\uB824\uC8FC\uC2E4\uB798\uC694?"
      sincerity: 0
    - key: DAY1_NPC_NORM_003_3
      id: 110031
      day: 1
      seq: 3
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_004_4
      content: "\uC720\uD488 \uAC10\uC815\uC744 \uC758\uB8B0\uBC1B\uC558\uC2B5\uB2C8\uB2E4.
        \uC5B4\uB290 \uACE0\uC778\uC758 \uBB3C\uAC74 \uC804\uBD80\uB97C\uC694. \uC720\uC871\uC774
        \uB514\uC9C0\uD138 \uC815\uB9AC\uAE4C\uC9C0 \uB9E1\uACA8\uC11C, \uD734\uB300\uD3F0
        \uC548\uC758 \uC571\uACFC \uACC4\uC815\uC744 \uD558\uB098\uD558\uB098 \uD655\uC778\uD574\uC57C
        \uD588\uC2B5\uB2C8\uB2E4. \uB3CC\uB824\uB4DC\uB9B4 \uAE30\uB85D\uACFC \uB2EB\uC744
        \uACC4\uC815\uC744 \uAC00\uB824\uB0B4\uB294 \uAC8C \uADF8 \uC77C\uC758 \uC808\uBC18\uC774\uB77C\uC11C\uC694."
      sincerity: 0
    - key: DAY1_NPC_NORM_004_4
      id: 110041
      day: 1
      seq: 4
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_005_5
      content: "\uADF8\uB7EC\uB2E4 \uCC98\uC74C \uBCF4\uB294 \uC571\uC744 \uC5F4\uC5C8\uB354\uB2C8,
        \uACE0\uC778\uC774 \uD314\uB85C\uC6B0\uD574 \uB454 \uCC44\uB110\uB4E4\uC774
        \uB5A0 \uC788\uC5C8\uC2B5\uB2C8\uB2E4. \uADF8\uC911 \uD558\uB098\uAC00 \uC5EC\uAE30\uC600\uC2B5\uB2C8\uB2E4.
        \uC81C\uAC00 \uCC3E\uC740 \uAC8C \uC544\uB2C8\uB77C, \uC8FD\uC740 \uC0AC\uB78C\uC758
        \uC190\uC744 \uAC70\uCCD0 \uB2FF\uC740 \uC148\uC785\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_005_5
      id: 120051
      day: 1
      seq: 5
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_006_6
      content: "\uC27D\uC9C0 \uC54A\uC740 \uACBD\uB85C\uC600\uACA0\uB124\uC694."
      sincerity: 0
    - key: DAY1_NPC_NORM_006_6
      id: 110061
      day: 1
      seq: 6
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_007_7
      content: "\uC81C\uAC00 \uD558\uC9C0 \uC54A\uC740 \uD589\uB3D9\uC774 \uD558\uB098
        \uC788\uC2B5\uB2C8\uB2E4. \uC815\uD655\uD788\uB294, \uD588\uC5B4\uC57C \uD588\uB294\uB370
        \uD558\uC9C0 \uC54A\uC740 \uD589\uB3D9\uC785\uB2C8\uB2E4. \uADF8\uAC78 \uD55C
        \uC0AC\uB78C\uC73C\uB85C \uB0A8\uACE0 \uC2F6\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_007_7
      id: 120071
      day: 1
      seq: 7
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_008_8
      content: "\u2026\uADF8\uAC8C \uBB50\uC600\uB294\uC9C0 \uC5EC\uCB64\uB3C4 \uB420\uAE4C\uC694?"
      sincerity: 0
    - key: DAY1_NPC_NORM_008_8
      id: 110081
      day: 1
      seq: 8
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_SEL_009_9
      content: "\uC21C\uC11C\uB300\uB85C \uB9D0\uC500\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.
        \uC800\uB294 \uBB3C\uAC74\uC758 \uC9C4\uC704\uB97C \uAC00\uB9BD\uB2C8\uB2E4.
        \uC9C4\uD488\uC778\uC9C0 \uAC00\uD488\uC778\uC9C0. \uADF8\uB7F0 \uC77C\uC744
        \uC624\uB798 \uD588\uC2B5\uB2C8\uB2E4. \uADF8\uB7F0\uB370 \uC774 \uC758\uB8B0\uB9CC\uD07C\uC740
        \uC81C\uAC00 \uAC10\uC815\uC778\uC774 \uC544\uB2C8\uB77C \uC758\uB8B0\uD488\uC785\uB2C8\uB2E4.
        \uC774\uC0C1\uD55C \uC790\uB9AC\uC785\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_SEL_009_9
      id: 120092
      day: 1
      seq: 9
      speaker: 2
      type: 2
      branch: 1A
      nextKey: DAY1_NPC_REAC_010_12
      content: "\uC5B4\uB5A4 \uC758\uB8B0\uD488\uC778\uC9C0, \uBCF4\uC5EC\uC8FC\uC2E4\uB798\uC694?"
      sincerity: 1
    - key: DAY1_PLAYER_SEL_009_10
      id: 120092
      day: 1
      seq: 9
      speaker: 2
      type: 2
      branch: 1B
      nextKey: DAY1_NPC_REAC_016_18
      content: "\uADF8 \uC55E\uC5D0 \uC549\uAE30\uAE4C\uC9C0, \uC624\uB798 \uB9DD\uC124\uC774\uC168\uACA0\uC5B4\uC694."
      sincerity: 3
    - key: DAY1_PLAYER_SEL_009_11
      id: 120092
      day: 1
      seq: 9
      speaker: 2
      type: 2
      branch: 1C
      nextKey: DAY1_NPC_REAC_019_21
      content: "\uB0A8\uC758 \uAC78 \uAC00\uB9AC\uB358 \uBD84\uC774, \uC624\uB298\uC740
        \uC790\uAE30 \uAC78 \uCC45\uC0C1\uC5D0 \uC62C\uB824\uB450\uC168\uB124\uC694.
        \u2026\uCC9C\uCC9C\uD788 \uBCFC\uAC8C\uC694."
      sincerity: 5
    - key: DAY1_NPC_REAC_010_12
      id: 110103
      day: 1
      seq: 10
      speaker: 1
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uBCF4\uC5EC\uB4DC\uB9B4 \uBB3C\uAC74\uC740 \uC5C6\uC2B5\uB2C8\uB2E4.
        \uD615\uCCB4\uAC00 \uC5C6\uB294 \uAC78 \uAC10\uC815\uD574 \uB2EC\uB77C\uB294
        \uAC70\uB2C8\uAE4C\uC694. \uADF8\uB798\uC11C \uC774\uC0C1\uD55C \uC790\uB9AC\uB77C\uACE0
        \uD588\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_011_13
      id: 120113
      day: 1
      seq: 11
      speaker: 2
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uD615\uCCB4\uAC00 \uC5C6\uC5B4\uB3C4, \uC724\uACFD\uC740 \uC788\uACA0\uC8E0."
      sincerity: 0
    - key: DAY1_NPC_REAC_012_14
      id: 110123
      day: 1
      seq: 12
      speaker: 1
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uC724\uACFD. \uC801\uC808\uD55C \uB2E8\uC5B4\uC785\uB2C8\uB2E4.
        \uC724\uACFD\uB9CC \uB0A8\uACE0 \uC548\uC740 \uBE44\uC5B4 \uC788\uC2B5\uB2C8\uB2E4.
        11\uB144\uC9F8 \uADF8 \uC724\uACFD\uB9CC \uB4E4\uC5EC\uB2E4\uBD24\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_013_15
      id: 120133
      day: 1
      seq: 13
      speaker: 2
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uADF8 \uC548\uC740, \uC65C \uC548 \uCC44\uC6CC\uC9C0\uB358\uAC00\uC694?"
      sincerity: 0
    - key: DAY1_NPC_REAC_014_16
      id: 110143
      day: 1
      seq: 14
      speaker: 1
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uCC44\uC6B0\uB824\uBA74 \uCD9C\uCC98\uAC00 \uBD84\uBA85\uD574\uC57C
        \uD558\uB294\uB370, 11\uB144\uC9F8 \uBD88\uBD84\uBA85\uD569\uB2C8\uB2E4.
        \uC815\uD655\uD788\uB294 11\uB144 4\uAC1C\uC6D4\uC785\uB2C8\uB2E4. \uC9C1\uC5C5\uBCD1\uC774\uC5D0\uC694.
        \uC5F0\uB3C4\uB97C \uC815\uD655\uD788 \uC548 \uC801\uC73C\uBA74 \uAC10\uC815\uC11C\uAC00
        \uBB34\uD6A8\uAC00 \uB418\uB2C8\uAE4C\uC694."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_015_17
      id: 120153
      day: 1
      seq: 15
      speaker: 2
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uADF8 \uBC84\uB987\uC774, \uC0AC\uB78C\uD55C\uD14C\uB3C4 \uB0A8\uC558\uB124\uC694."
      sincerity: 0
    - key: DAY1_NPC_REAC_016_18
      id: 110163
      day: 1
      seq: 16
      speaker: 1
      type: 4
      branch: 1B
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uB9DD\uC124\uC600\uC2B5\uB2C8\uB2E4. \uC815\uD655\uD788\uB294, \uB9DD\uC124\uC600\uB2E4\uAE30\uBCF4\uB2E4
        \uC808\uCC28\uB97C \uAC80\uD1A0\uD588\uB2E4\uACE0 \uD574\uC57C \uB9DE\uACA0\uC2B5\uB2C8\uB2E4.
        \uC5B4\uB5A4 \uC758\uB8B0\uB4E0 \uBC1B\uAE30 \uC804\uC5D0 \uC9C4\uC704\uBD80\uD130
        \uB530\uC9C0\uB294 \uAC8C \uC81C \uC77C\uC774\uB77C\uC11C\uC694."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_017_19
      id: 120173
      day: 1
      seq: 17
      speaker: 2
      type: 4
      branch: 1B
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uADF8\uB798\uC11C, \uACB0\uB860\uC740 \uB098\uC168\uC5B4\uC694?"
      sincerity: 0
    - key: DAY1_NPC_REAC_018_20
      id: 110183
      day: 1
      seq: 18
      speaker: 1
      type: 4
      branch: 1B
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uADF8\uB807\uC2B5\uB2C8\uB2E4. \uC81C \uC758\uB8B0\uC758 \uC9C4\uC704\uBD80\uD130\uC694.
        \uC9C4\uC9DC\uB85C \uBC14\uAFB8\uACE0 \uC2F6\uC740 \uAC74\uC9C0, \uADF8\uB0E5
        \uB4E4\uC5EC\uB2E4\uBCF4\uACE0 \uC2F6\uC740 \uAC74\uC9C0. \uC544\uC9C1 \uD310\uC815\uC774
        \uC548 \uB0AC\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_NPC_REAC_019_21
      id: 110193
      day: 1
      seq: 19
      speaker: 1
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uC62C\uB824\uB480\uC2B5\uB2C8\uB2E4. \uC7A5\uAC11\uC744 \uB07C\uACE0\uC694.
        \uBB3C\uAC74\uC744 \uB2E4\uB8F0 \uB54C \uB298 \uC7A5\uAC11\uC744 \uB08D\uB2C8\uB2E4.
        \uADF8\uB7F0\uB370 \uC81C \uAE30\uC5B5\uC744 \uC62C\uB824\uB450\uB294\uB370\uB3C4
        \uC7A5\uAC11\uC744 \uB07C\uACE0 \uC2F6\uB354\uAD70\uC694."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_020_22
      id: 120203
      day: 1
      seq: 20
      speaker: 2
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uC65C \uADF8\uB807\uAC8C\uAE4C\uC9C0, \uC870\uC2EC\uD558\uC2DC\uB294
        \uAC70\uC608\uC694?"
      sincerity: 0
    - key: DAY1_NPC_REAC_021_23
      id: 110213
      day: 1
      seq: 21
      speaker: 1
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uB9E8\uC190\uC73C\uB85C \uB9CC\uC9C0\uBA74 \uC9C0\uBB38\uC774 \uB0A8\uC2B5\uB2C8\uB2E4.
        \uBB3C\uAC74\uC5D0. \uADF8\uB9AC\uACE0 \uC0AC\uB78C\uD55C\uD14C\uB3C4 \uD754\uC801\uC774
        \uB0A8\uB294\uB2E4\uB294 \uAC78, \uD55C \uBC88 \uBC30\uC6B4 \uC801\uC774
        \uC788\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_022_24
      id: 120223
      day: 1
      seq: 22
      speaker: 2
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\u2026"
      sincerity: 0
    - key: DAY1_NPC_REAC_023_25
      id: 110233
      day: 1
      seq: 23
      speaker: 1
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uC9C0\uAE08 \uC544\uBB34 \uB2F5\uB3C4 \uC548 \uD558\uC2DC\uB294\uAD70\uC694.
        \uB5A0\uBCF4\uB824\uB294 \uCE68\uBB35\uC785\uB2C8\uAE4C, \uC544\uB2C8\uBA74
        \uADF8\uB0E5 \uAE30\uB2E4\uB9AC\uB294 \uAC81\uB2C8\uAE4C. \uC800\uB294 \uADF8
        \uCC28\uC774\uB97C \uC77D\uB294 \uC77C\uC744 \uD588\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_REAC_024_26
      id: 120243
      day: 1
      seq: 24
      speaker: 2
      type: 4
      branch: 1C
      nextKey: DAY1_NPC_NORM_025_27
      content: "\uAE30\uB2E4\uB9AC\uB294 \uCABD\uC774\uC5D0\uC694. \uCC9C\uCC9C\uD788
        \uD558\uC138\uC694."
      sincerity: 0
    - key: DAY1_NPC_NORM_025_27
      id: 110251
      day: 1
      seq: 25
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_026_28
      content: "\uC5B4\uCA0C\uB4E0 \uC758\uB8B0 \uB0B4\uC6A9\uC744 \uC815\uB9AC\uD558\uACA0\uC2B5\uB2C8\uB2E4.
        \uD55C \uC0AC\uB78C\uC774 \uC800\uC5D0\uAC8C \uC190\uC744 \uBED7\uC740 \uC801\uC774
        \uC788\uB294\uB370, \uC800\uB294 \uADF8 \uC190\uC744 \uC7A1\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_026_28
      id: 120261
      day: 1
      seq: 26
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_027_29
      content: "\uC774\uC720\uAC00 \uC788\uC5C8\uB098\uC694?"
      sincerity: 0
    - key: DAY1_NPC_NORM_027_29
      id: 110271
      day: 1
      seq: 27
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_028_30
      content: "\uD655\uC2E0\uC774 \uC11C\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_028_30
      id: 120281
      day: 1
      seq: 28
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_029_31
      content: "\uBBFF\uC74C\uC774 \uD544\uC694\uD588\uB358 \uAC74\uAC00\uC694?"
      sincerity: 0
    - key: DAY1_NPC_NORM_029_31
      id: 110291
      day: 1
      seq: 29
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_030_32
      content: "\uD45C\uD604\uC774 \uBD80\uC815\uD655\uD588\uC2B5\uB2C8\uAE4C. \uC815\uD655\uD788\uB294,
        \uC81C\uAC00 \uBFCC\uB9AC\uCCE4\uC2B5\uB2C8\uB2E4. \uB450 \uD45C\uD604\uC758
        \uBB34\uAC8C\uAC00 \uB2E4\uB974\uB2E4\uB294 \uAC78, \uADF8\uCABD\uC740 \uC544\uC2DC\uB294\uAD70\uC694."
      sincerity: 0
    - key: DAY1_PLAYER_NORM_030_32
      id: 120301
      day: 1
      seq: 30
      speaker: 2
      type: 1
      branch: 
      nextKey: DAY1_NPC_NORM_031_33
      content: "\uB354 \uC815\uD655\uD55C \uCABD\uC744, \uACE0\uB974\uC168\uB124\uC694."
      sincerity: 0
    - key: DAY1_NPC_NORM_031_33
      id: 110311
      day: 1
      seq: 31
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_SEL_032_34
      content: "\uC815\uD655\uD55C \uAC8C \uB298 \uD3B8\uD55C \uAC74 \uC544\uB2D9\uB2C8\uB2E4.
        \uADF8\uB798\uB3C4 \uAC10\uC815\uC11C\uC5D4 \uC815\uD655\uD55C \uB2E8\uC5B4\uB9CC
        \uC801\uC2B5\uB2C8\uB2E4. \uC624\uB298\uC740 \uC81C\uAC00 \uC758\uB8B0\uD488\uC774\uB2C8,
