      seq: 5
      speaker: 1
      type: 1
      branch: 
      nextKey: DAY1_PLAYER_NORM_006_6
      content: "\uC544\uB2C8 \uB410\uACE0. \uBCA0\uB080 \uAC74 \uC544\uB2D0 \uD14C\uACE0
