      branch: 1A
      nextKey: DAY1_PLAYER_REAC_004_6
      content: "\uC81C\uAC00 \uD558\uC9C0 \uC54A\uC740 \uD589\uB3D9\uC774 \uC788\uB294\uB370\uC694.
