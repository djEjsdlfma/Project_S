      day: 1
      seq: 7
      speaker: 1
      type: 4
      branch: 1B
      nextKey: DAY1_NPC_REAC_008_10
      content: "\uADF8 \uC548\uC5D0 \uC774 \uC571\uC774 \uAE54\uB824 \uC788\uC5B4\uC11C
