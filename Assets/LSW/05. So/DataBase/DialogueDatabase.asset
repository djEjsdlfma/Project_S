      speaker: 1
      type: 4
      branch: 1A
      nextKey: DAY1_NPC_NORM_012_16
      content: "\uB124. \uD588\uC5B4\uC57C \uD588\uB294\uB370 \uD558\uC9C0 \uC54A\uC740
