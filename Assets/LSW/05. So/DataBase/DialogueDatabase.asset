      day: 1
      seq: 8
      speaker: 1
      type: 4
      branch: 1B
      nextKey: DAY1_PLAYER_REAC_007_11
      content: "\uC774 \uCC44\uB110\uC744 \uD314\uB85C\uC6B0\uD55C \uD754\uC801\uC744
