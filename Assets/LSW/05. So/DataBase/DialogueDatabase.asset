      day: 1
      seq: 6
      speaker: 1
      type: 4
      branch: 1B
      nextKey: DAY1_NPC_REAC_007_9
      content: "\uC758\uB8B0\uC778\uC774 \uAC00\uC838\uC628 \uC720\uD488 \uC18D\uC5D0
        \uC624\uB798\uB41C \uD734\uB300\uD3F0\uC774 \uC788\uC5C8\uC2B5\uB2C8\uB2E4."
