  wordList:
  - "\uC870\uAC01\uC744 \uC9D1\uC5B4\uB4E0\uB2E4. \uC74C\uD45C\uB4E4\uC774 \uBCF4\uC778\uB2E4
    \u2014 \uC900\uBE44\uD588\uB358 \uC1FC\uD33D\uC774 \uC544\uB2C8\uB2E4. \uC989\uD765\uC73C\uB85C
