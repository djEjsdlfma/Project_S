  wordList:
  - "\uD640 \uC785\uAD6C\uB85C \uB2E4\uAC00\uAC04\uB2E4. \uC720\uB9AC\uBB38 \uB108\uBA38\uB85C
    \uBB34\uB300\uAC00 \uBCF4\uC778\uB2E4.\\n\uB2E4\uB978 \uCC38\uAC00\uC790\uAC00
    \uC5F0\uC8FC\uB97C \uB05D\uB0B4\uACE0 \uC778\uC0AC\uD558\uACE0 \uC788\uB2E4.
    \uBC15\uC218 \uC18C\uB9AC."
  - "\uC190\uB2D8\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB4E4\uB9B0\uB2E4."
  - "\uC724\uC11C\uC544: \uC800 \uBC15\uC218... \uBC1B\uC744 \uC218 \uC788\uC5C8\uB294\uB370."
  - ...
  - "\uADFC\uB370 \uD6C4\uD68C\uB294 \uC548 \uD574\uC694. \uADF8 \uC989\uD765\uACE1\uC744
    \uCE5C \uAC8C."
  - "\uAE30\uC5B5 \uC218\uC120\uC18C: \uC5B4\uC9F8\uC11C\uC8E0?"
  - "(\uC190\uB2D8\uC774 \uC870\uC6A9\uD788 \uB9D0\uD55C\uB2E4.)"
  - "\uC724\uC11C\uC544: \uADF8\uAC8C \uC9C4\uC9DC\uC600\uC73C\uB2C8\uAE4C. \uADF8\uB0A0
    \uC81C\uAC00 \uCE60 \uC218 \uC788\uB294 \uAC83 \uC911\uC5D0."
  takePictureEvent:
    m_PersistentCalls:
      m_Calls: []
  endDialogueEvent:
